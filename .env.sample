# ─── App ─────────────────────────────────────────────────────────────────────
# The canonical public URL of the app (no trailing slash)
# Local: http://localhost:3000 — Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Neon (PostgreSQL) ────────────────────────────────────────────────────────
# Found in: Neon Dashboard → your project → Connection Details (use Pooled connection)
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Must match NEXT_PUBLIC_SITE_URL — Better Auth uses this to build callback URLs
# Local: http://localhost:3000 — Production: https://stride-web-frontend.vercel.app
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=<random-32-byte-hex-secret>

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-<your-google-client-secret>

# ─── Cashfree Payments ───────────────────────────────────────────────────────
# Found in: Cashfree Dashboard → Developers → API Keys
STRIDE_CASHFREE_APP_ID=<your-cashfree-app-id>
STRIDE_CASHFREE_SECRET_KEY=<your-cashfree-secret-key>
# "sandbox" for test/staging, "production" for live payments
STRIDE_CASHFREE_ENV=sandbox
